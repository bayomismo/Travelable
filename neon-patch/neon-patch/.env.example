# Travelable environment variables
# Copy this to .env and fill in real values for local development.

# ─── Database ──────────────────────────────────────────────────────────────
# Local development (SQLite):
#   DATABASE_URL="file:./prisma/dev.db"
#
# Production (Neon PostgreSQL — recommended):
#   1. Create a free project at https://neon.tech
#   2. Copy the connection string from the Neon dashboard
#   3. Paste it below (keep ?sslmode=require)
DATABASE_URL="file:./prisma/dev.db"

# ─── Auth ──────────────────────────────────────────────────────────────────
# HMAC secret for signing session cookies.
# Generate a strong one for production:
#   openssl rand -hex 32
#   (Windows: [System.BitConverter]::ToString((1..32 | %{[byte](Get-Random -Max 256)})).Replace('-','').ToLower())
NEXTAUTH_SECRET="change-me-in-production-with-openssl-rand-hex-32"

# Canonical app URL (used in metadata + cookies)
NEXTAUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# ─── Optional: AI features ─────────────────────────────────────────────────
# If you want richer AI responses (instead of the built-in fallback), set:
#   ZAI_API_KEY="<your-key>"
# The app will continue to work without this; it just won't use the LLM.
# ZAI_API_KEY=""