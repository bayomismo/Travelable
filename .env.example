# Travelable environment variables
# Copy this to .env and fill in real values for local development.

DATABASE_URL="file:./prisma/dev.db"

# HMAC secret for signing session cookies.
# Generate a strong one for production:
#   openssl rand -hex 32
NEXTAUTH_SECRET="change-me-in-production-with-openssl-rand-hex-32"

# Canonical app URL (used in metadata)
NEXTAUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"
